---
import { site } from '../config/site';

interface Props {
  size?: 'sm' | 'md';
}

const { size = 'md' } = Astro.props;
const base = import.meta.env.BASE_URL;

const sizeClasses = {
  sm: 'text-sm',
  md: 'text-base sm:text-lg',
};
---

<a
  href={base}
  class:list={['logo group inline-flex items-baseline gap-0 font-mono font-medium tracking-tight', sizeClasses[size]]}
  aria-label={`${site.name}, home`}
>
  <span class="text-zinc-500 transition-colors group-hover:text-terminal-dim">~/</span>
  <span class="text-terminal transition-colors group-hover:text-terminal-bright">{site.handle}</span>
  <span class="cursor-blink ml-px inline-block h-[1.1em] w-[0.55em] translate-y-[0.12em] bg-terminal" aria-hidden="true" />
</a>

<style>
  .cursor-blink {
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
